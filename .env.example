# ==============================================================================
# VCOREX INSTITUTIONAL - OKX TRADING BOT
# FILE MẪU — Đổi tên thành .env và điền thông tin của bạn
# Đồng bộ: docs/4_chien_luoc.md v1.1 | core/config/settings.py
# Cài đặt: pip install -r requirements-dev.txt
# ==============================================================================

# ==============================================================================
# OKX API — Kết nối sàn
# ==============================================================================
OKX_API_KEY=your_okx_api_key_here
OKX_API_SECRET=your_okx_api_secret_here
OKX_PASSPHRASE=your_okx_passphrase_here
OKX_DEMO_MODE=true                  # true = tài khoản Demo OKX | false = Mainnet (tiền thật)

# Tùy chọn — thường không cần sửa (bootstrap tự chọn theo DEMO/LIVE)
# OKX_BASE_URL=https://openapi.okx.com
# OKX_WS_URL=wss://wspap.okx.com:8443/ws/v5

# ==============================================================================
# TELEGRAM — Dashboard & điều khiển bot
# ==============================================================================
TELEGRAM_ENABLED=true               # Bật bot Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
TELEGRAM_ADMIN_IDS=["your_telegram_user_id"]   # JSON list — chỉ ID này được bấm nút điều khiển
TELEGRAM_NOTIFICATION_SIGNALS=true  # Thông báo tín hiệu EMA mới
TELEGRAM_NOTIFICATION_TRADES=true   # Thông báo lệnh khớp / đóng vị thế
TELEGRAM_NOTIFICATION_DAILY_REPORT=true
TELEGRAM_NOTIFY_REJECTIONS=true     # Tín hiệu bị lọc (ADX, body, stale, …)

# ==============================================================================
# WATCHLIST & RADAR — Coin bot theo dõi
# Thứ tự trong list = ưu tiên. RADAR_LIMIT cắt từ đầu danh sách.
# Format đơn dòng (đảm bảo hoạt động) hoặc format pro multi-line (xem comment bên dưới)
# ==============================================================================
# Format đơn dòng (recommended):
WATCHLIST=["BTC-USDT-SWAP","ETH-USDT-SWAP","SOL-USDT-SWAP","BNB-USDT-SWAP","XRP-USDT-SWAP","ADA-USDT-SWAP","DOGE-USDT-SWAP","TON-USDT-SWAP","AVAX-USDT-SWAP","LINK-USDT-SWAP","TRX-USDT-SWAP","DOT-USDT-SWAP","BCH-USDT-SWAP","NEAR-USDT-SWAP","LTC-USDT-SWAP","ATOM-USDT-SWAP","ARB-USDT-SWAP","FIL-USDT-SWAP","SUI-USDT-SWAP","ETC-USDT-SWAP"]
# Format pro multi-line (chỉ dùng nếu muốn dễ đọc hơn):
# WATCHLIST=[
#     # TOP 5 - Blue Chips (Highest Liquidity)
#     "BTC-USDT-SWAP",   # Bitcoin #1
#     "ETH-USDT-SWAP",   # Ethereum #2
#     "SOL-USDT-SWAP",   # Solana #5
#     "BNB-USDT-SWAP",   # Binance Coin #4
#     "XRP-USDT-SWAP",   # XRP #6
#     
#     # TOP 6-10 - Major Altcoins
#     "ADA-USDT-SWAP",   # Cardano #9
#     "DOGE-USDT-SWAP",  # Dogecoin #8
#     "TON-USDT-SWAP",   # Toncoin #9
#     "AVAX-USDT-SWAP",  # Avalanche #10
#     "LINK-USDT-SWAP",  # Chainlink #13
#     
#     # TOP 11-15 - Established Projects
#     "TRX-USDT-SWAP",   # TRON #11
#     "DOT-USDT-SWAP",   # Polkadot #14
#     "BCH-USDT-SWAP",   # Bitcoin Cash #16
#     "NEAR-USDT-SWAP",  # NEAR Protocol #17
#     "LTC-USDT-SWAP",   # Litecoin #18
#     
#     # TOP 16-20 - Growth & DeFi
#     "ATOM-USDT-SWAP",  # Cosmos #46
#     "ARB-USDT-SWAP",   # Arbitrum #34
#     "FIL-USDT-SWAP",   # Filecoin #26
#     "SUI-USDT-SWAP",   # Sui #38
#     "ETC-USDT-SWAP",   # Ethereum Classic #21
# ]
RADAR_LIMIT=20                        # Số coin quét đồng thời (5/10/15/20). Đổi được qua nút Telegram

# ==============================================================================
# VỐN, ĐÒN BẨY & PHÍ
# ==============================================================================
DEFAULT_LEVERAGE=10                 # Đòn bẩy mỗi lệnh (khớp chiến lược EMA)
MAX_LEVERAGE=10                     # Trần đòn bẩy — kiểm tra khi PRODUCTION_RISK_MODE=true
MARGIN_PER_ORDER_USDT=1000          # Ký quỹ mỗi lệnh (USDT) → quy mô = margin × leverage
MARGIN_MODE=isolated                # isolated | cross — chế độ ký quỹ OKX
MAX_DAILY_DRAWDOWN=0.30             # Sụt giảm tối đa trong ngày (0.30 = 30%) → dừng bot nếu vượt
MAKER_FEE_RATE=0.0002               # Phí maker 0.02%
TAKER_FEE_RATE=0.0005               # Phí taker 0.05%
TICKER_TTL_SECONDS=10               # Giá ticker cache tối đa (giây) trước khi coi là cũ

# ==============================================================================
# TP / SL theo ROE (%) — docs mục 4
# Công thức: biến_động_giá% = (ROE% + FEE_ROE_BUFFER_PCT) / (100 × leverage)
# ==============================================================================
SL_ROE_PCT=50.0                     # Cắt lỗ khi ROE âm ~50%
TP1_ROE_PCT=50.0                    # Chốt lời mốc 1
TP2_ROE_PCT=100.0
TP3_ROE_PCT=150.0
TP1_EXIT_PCT=0.5                    # Đóng 50% vị thế tại TP1 (dạng thập phân 0–1)
TP2_EXIT_PCT=0.3                    # Đóng 30% tại TP2
TP3_EXIT_PCT=0.2                    # Đóng 20% tại TP3
FEE_ROE_BUFFER_PCT=0.20             # Bù phí: taker 0.05% × 2 chiều × margin an toàn 2x

# ==============================================================================
# QUẢN TRỊ RỦI RO (Risk Manager)
# ==============================================================================
# PRODUCTION_RISK_MODE=false (demo): bỏ qua kiểm tra margin, R:R, max risk/vốn
# PRODUCTION_RISK_MODE=true (live): bật đủ gate production
PRODUCTION_RISK_MODE=false
MIN_RISK_REWARD_RATIO=1.5           # Tỷ lệ lợi nhuận TP1 / rủi ro SL tối thiểu (chỉ khi production risk)
MAX_RISK_ALLOWED_PCT=0.20           # Rủi ro tối đa mỗi lệnh = % equity (chỉ khi production risk)
MAX_SYMBOL_CONCENTRATION=9999       # Số vị thế tối đa / 1 symbol (count). Demo có thể 9999 = tắt guard
MAX_OPEN_POSITIONS=9999             # Tổng vị thế mở. 9999 = không giới hạn (demo)

# ==============================================================================
# CHIẾN LƯỢC EMA CROSSOVER — docs mục 1–3
# ==============================================================================
EMA_FAST_PERIOD=9                   # EMA nhanh (Golden/Death cross)
EMA_SLOW_PERIOD=21                  # EMA chậm
COOLDOWN_MINUTES=0                  # Nghỉ giữa 2 tín hiệu cùng symbol+TF (phút). 0 = tắt (demo)
ENABLE_DEFAULT_STRATEGY=true      # Bật chiến lược EMA khi khởi động

# --- Bộ lọc ADX (sức mạnh xu hướng) ---
# ADX = 0 (chưa đủ nến) → bỏ qua filter. ADX > 0 và < ngưỡng → từ chối (weak_trend_adx)
ADX_MIN_THRESHOLD_ALL=25.0          # TF ngắn: 5m, 15m, 1H
ADX_MIN_THRESHOLD_LONG_TF=20.0      # TF dài: 4H, 1D, 1W, 1M

# --- Lọc thân nến động (body %) — từ chối Doji / nến yếu (body_too_small) ---
# Công thức: |close-open| / (high-low) × 100 >= ngưỡng TF
MIN_BODY_PERCENTAGE_5M=1.0
MIN_BODY_PERCENTAGE_15M=2.5
MIN_BODY_PERCENTAGE_1H=5.0
MIN_BODY_PERCENTAGE_4H=6.0
MIN_BODY_PERCENTAGE_1D=7.5
MIN_BODY_PERCENTAGE_1W=10.0
MIN_BODY_PERCENTAGE_1M=12.0

# --- CONFIRMATION CANDLES (Chế độ vào lệnh) ---
# 0 = REALTIME MODE: Vào lệnh ngay khi EMA crossover phát hiện (không đợi nến đóng)
# 1 = CONFIRMATION MODE: Vào lệnh khi nến đóng (đợi xác nhận)
CONFIRMATION_CANDLES_5M=1
CONFIRMATION_CANDLES_15M=1
CONFIRMATION_CANDLES_1H=1
CONFIRMATION_CANDLES_4H=1
CONFIRMATION_CANDLES_1D=0
CONFIRMATION_CANDLES_1W=0
CONFIRMATION_CANDLES_1M=0

# --- Stale signal — từ chối tín hiệu quá cũ (stale_signal) ---
# Đo từ lúc nến đóng đến khi bot xử lý; hard cap cố định (giây)
STALE_SIGNAL_5M_SECONDS=60
STALE_SIGNAL_15M_SECONDS=180
STALE_SIGNAL_1H_SECONDS=720
STALE_SIGNAL_4H_SECONDS=2880
STALE_SIGNAL_1D_SECONDS=17280
STALE_SIGNAL_1W_SECONDS=120960
STALE_SIGNAL_1M_SECONDS=518400

# ==============================================================================
# HỆ THỐNG & CƠ SỞ DỮ LIỆU
# ==============================================================================
LOG_LEVEL=INFO                      # DEBUG | INFO | WARNING | ERROR — INFO để thấy [SIGNAL_REJECTED]
DATABASE_URL=sqlite:///data/vcorex.db
DATABASE_WAL_MODE=true              # SQLite WAL — ghi nhanh, an toàn khi tắt bot
ENVIRONMENT=development             # development | production — cảnh báo nếu lệch OKX_DEMO_MODE
REDIS_URL=redis://localhost:6379    # EventBus Redis (fallback in-memory nếu không kết nối được)

# Shutdown: false khi chuyển máy chủ để GIỮ vị thế (docs/9_chuyen_may_chu.md)
SHUTDOWN_LIQUIDATE_ON_EXIT=true

# ==============================================================================
# HIỆU NĂNG & CIRCUIT BREAKER
# ==============================================================================
MAX_LATENCY_TOLERANCE_MS=50.0
MAX_SLIPPAGE_TOLERANCE_BPS=20

# Circuit breaker đóng lệnh Telegram (demo: tắt)
CB_THRESHOLD=9999                   # Số lỗi liên tiếp → OPEN. 9999 = tắt
CB_COOLDOWN_SECONDS=0

# Circuit breaker riêng PositionEngine (mặc định trong settings nếu không khai báo)
# POSITION_CB_THRESHOLD=5
# POSITION_CB_COOLDOWN=30.0

# ==============================================================================
# TÍNH NĂNG NÂNG CAO (tùy chọn — mặc định trong settings.py)
# ==============================================================================
# ENABLE_STRICT_ACCOUNT_SEEDING=true    # Chờ snapshot WS trước khi vào lệnh
# ENABLE_PHANTOM_VERIFIER=true          # Xác minh lệnh treo sau reconnect
# SHUTDOWN_LIQUIDATE_ON_EXIT=false      # Chuyển VPS: không đóng vị thế khi Ctrl+C
