    # TEST 6: ROE (Return on Equity) Calculation
    # =========================================================================
    def test_roe_calculation(self, risk_manager):
        """Test Return on Equity = P&L / Initial Margin."""
        # Long position BTC @68500, current price 71925 (+5%)
        entry_price = 68500.0
        current_price = 71925.0
        amount = 0.0146  # ~$1000 notional
        leverage = 20
        roe = risk_manager.calculate_roe(entry_price, current_price, amount, leverage, "long")
        assert roe > 0, "ROE phải dương khi vị thế có lãi"
        # +5% * 20 = 100% ROE
        assert abs(roe - 100) < 5, f"ROE sai: {roe}% nên khoảng 100%"
        
        # Thua $25 trên margin $50 -> ROE -50%
        bad_current_price = 67815  # -1%
        roe_loss = risk_manager.calculate_roe(entry_price, bad_current_price, amount, leverage, "long")
        assert roe_loss < 0, "ROE phải âm khi vị thế lỗ"
    
    # =========================================================================
    # TEST 7: Institutional Requirements - All calculations must be accurate
    # =========================================================================
    def test_all_20_coins_calculations_valid(self, risk_manager, test_settings):
        """Test tất cả 20 OKX coins đều pass các tính toán."""
        from utils.okx_symbols import OKX_SYMBOL_SPECS
        # Chọn các coin phổ biến để test
        test_coins = ["BTC-USDT", "ETH-USDT", "SOL-USDT", "XRP-USDT"]
        for symbol in test_coins:
            if symbol not in OKX_SYMBOL_SPECS:
                continue
            specs = OKX_SYMBOL_SPECS[symbol]
            assert specs is not None, f"Không tìm thấy specs cho {symbol}"
            # Dùng giá tham chiếu cố định cho test
            price_map = {"BTC-USDT":68500, "ETH-USDT":3500, "SOL-USDT":145, "XRP-USDT":0.52}
            price = price_map[symbol]
            notional = 1000.0
            size = notional / price
            leverage = test_settings.default_leverage  # 20
            margin = notional / leverage
            
            # Kiểm tra size nằm trong min/max OKX
            assert size >= specs['min_size'], f"{symbol} size {size} < min {specs['min_size']}"
            assert margin >= 100 * 0.99 and margin <= 100 * 1.01, f"{symbol} margin {margin} != ~$100"
            
            # Test SL/TP calculation
            sl = risk_manager.calculate_stop_loss(price, "buy", 0.02)
            tp = risk_manager.calculate_take_profits(price, "buy", [0.05])[0]
            
            assert sl < price, f"{symbol} SL > entry"
            assert tp > price, f"{symbol} TP < entry"
            
            # P&L calculation
            pnl = risk_manager.calculate_pnl(price, tp, "long", size)
            assert pnl > 0, f"{symbol} P&L âm khi giá tăng đến TP"