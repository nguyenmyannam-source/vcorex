    def test_sl_minimum_distance_validation(self, risk_manager):
        """Test SL không được đặt quá gần entry price (tránh bị hit sớm)."""
        entry_price = 68500.0
        
        # SL quá gần - chỉ 0.1% (0.001) - không hợp lệ
        sl_too_close = entry_price * 0.999  # -0.1%
        assessment = risk_manager._validate_sl_distance(entry_price, sl_too_close, "buy")
        assert assessment.approved == False
        assert "SL too close to entry" in assessment.reason
        
        # SL hợp lệ - 1.5%
        sl_valid = entry_price * 0.985  # -1.5%
        assessment = risk_manager._validate_sl_distance(entry_price, sl_valid, "buy")
        assert assessment.approved == True
    
