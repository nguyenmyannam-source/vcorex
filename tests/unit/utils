    def test_partial_tp_pnl_calculation(self, risk_manager):
        """Test P&L khi chốt TP một phần (partial take profit)."""
        # TP1: đóng 50% vị thế ở +2%
        entry_price = 68500.0
        tp1_price = 68500 * 1.02  # 69870
        partial_amount = 0.0146 * 0.5  # 50% of total amount
        pnl1 = risk_manager.calculate_pnl(entry_price, tp1_price, "long", partial_amount)
        
        expected_pnl1 = (69870 - 68500) * (0.0146 * 0.5)  # 1370 * 0.0073 = ~$10.001
