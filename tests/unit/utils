    def test_tp_risk_reward_ratio_validation(self, risk_manager):
        """Test Risk/Reward ratio phải >= 1.5 (institutional requirement)."""
        entry_price = 68500.0
        sl_price = 67130  # -2%
        tp_price = 71925  # +5%
        
        # Calculate R:R
        risk = entry_price - sl_price  # 1370
        reward = tp_price - entry_price  # 3425
        rr_ratio = reward / risk  # ~2.5
        
        assert rr_ratio >= 1.5, f"R:R quá thấp: {rr_ratio}"
        
        # Risk manager phải validate R:R
        assessment = risk_manager.validate_risk_reward(entry_price, sl_price, tp_price)
        assert assessment.approved == True
        
        # R:R quá thấp (0.8) - bị reject
        bad_tp = 69500  # +1.45%
        bad_reward = bad_tp - entry_price  # 1000
        bad_rr = bad_reward / risk  # ~0.73
        assert bad_rr < 1.5
        
        assessment = risk_manager.validate_risk_reward(entry_price, sl_price, bad_tp)
        assert assessment.approved == False
        assert "Risk/Reward ratio too low" in assessment.reason
    
