    # =========================================================================
    # TEST 2: Stop Loss (SL) Calculation
    # =========================================================================
    def test_sl_calculation_long_position(self, risk_manager):
        """Test SL calculation cho vị thế LONG ( BUY )."""
        # LONG BTC @ 68500, SL 2% below entry
        entry_price = 68500.0
        stop_loss_pct = 0.02  # 2%
        expected_sl = entry_price * (1 - stop_loss_pct)  # 68500 * 0.98 = 67130
        
        calculated_sl = risk_manager.calculate_stop_loss(entry_price, "long", stop_loss_pct)
        assert abs(calculated_sl - expected_sl) < 0.01, f"SL sai: {calculated_sl} != {expected_sl}"
        
        # SL phải thấp hơn entry price cho vị thế LONG
        assert calculated_sl < entry_price, "SL LONG phải < entry price"
    
    def test_sl_calculation_short_position(self, risk_manager):
        """Test SL calculation cho vị thế SHORT ( SELL )."""
        # SHORT BTC @ 68500, SL 2% above entry
        entry_price = 68500.0
        stop_loss_pct = 0.02  # 2%
        expected_sl = entry_price * (1 + stop_loss_pct)  # 68500 * 1.02 = 69870
        
        calculated_sl = risk_manager.calculate_stop_loss(entry_price, "short", stop_loss_pct)
        assert abs(calculated_sl - expected_sl) < 0.01, f"SL sai: {calculated_sl} != {expected_sl}"
        
        # SL phải cao hơn entry price cho vị thế SHORT
